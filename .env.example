# ─── Database ─────────────────────────────────────────────────
# Local PostgreSQL (default):
DATABASE_URL=postgresql://postgres:1210@localhost:5432/whatapply?schema=public

# ─── Auth ─────────────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production!
JWT_SECRET=whatapply-change-this-secret-in-production

# ─── Gemini AI ────────────────────────────────────────────────
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ─── WhatsApp Business API (for production mode) ──────────────
# Leave blank to use sandbox mode
WA_VERIFY_TOKEN=whatapply-webhook-token

# ─── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
